# =============================
# Django environment selection
# =============================
# dev | prod
DJANGO_ENV=dev

# Django secret key (BẮT BUỘC thay giá trị thật khi chạy production)
DJANGO_SECRET_KEY=change-me-to-a-strong-secret-key

# Comma-separated hosts, ví dụ: api.example.com,localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Backend base URL used by some features (QR/media links)
KHO_BACKEND_BASE_URL=http://localhost:8000

# =============================
# CORS
# =============================
# true/false
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOW_CREDENTIALS=true
# Comma-separated origins, ví dụ: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# =============================
# Database (PostgreSQL)
# =============================
# Nếu dùng Docker Compose hiện tại, DB_HOST nên là: db
DB_HOST=db
DB_PORT=5432
DB_NAME=devdb
DB_USER=devuser
DB_PASS=changeme

# =============================
# Docker / app runtime helpers
# =============================
APP_PORT=8000
BUILD_TARGET=development
DEV=true

# =============================
# AI documents worker
# =============================
DOCUMENTS_USE_CELERY=true
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_WORKER_CONCURRENCY=2
