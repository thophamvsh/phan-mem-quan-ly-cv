# =============================
# Production environment
# =============================
DJANGO_ENV=prod
DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret

# API/backend domain names allowed by Django.
# Example: api.example.com,localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=api.example.com,localhost,127.0.0.1

# Browser origins allowed to call the API.
# Example: https://app.example.com,https://admin.example.com
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_ORIGINS=https://app.example.com
KHO_BACKEND_BASE_URL=https://api.example.com

# =============================
# Production PostgreSQL
# =============================
DB_HOST=db
DB_PORT=5432
DB_NAME=vsh_prod
DB_USER=vsh_user
DB_PASS=change-me

# =============================
# Runtime
# =============================
APP_PORT=8000
DOCUMENTS_USE_CELERY=True
REALTIME_SNAPSHOT_SCHEDULER_ENABLED=False
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TIMEZONE=Asia/Ho_Chi_Minh
CELERY_WORKER_CONCURRENCY=2

# Google Sheet service account files mounted by docker-compose.prod.yml.
SONGHINH_GOOGLE_CREDENTIALS=/run/secrets/vsh/songhinh-google.json
VINHSON_GOOGLE_CREDENTIALS=/run/secrets/vsh/vinhson-google.json

# Set these to 0 if migrations/static collection are run as separate deploy steps.
RUN_MIGRATIONS=1
COLLECTSTATIC=1

# Optional one-time superuser bootstrap.
CREATE_SUPERUSER=0
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password

# =============================
# External integrations
# =============================
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
AI_TOOLS_PROVIDER=deepseek
AI_TOOLS_OPENAI_MODEL=gpt-4o-mini
AI_TOOLS_DEEPSEEK_MODEL=deepseek-chat
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VRAIN_API_KEY=
