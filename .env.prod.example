# =============================
# Production environment
# =============================
DJANGO_ENV=prod
DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret

# API/backend domain names allowed by Django.
# Example: api.example.com,localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=api.example.com,localhost,127.0.0.1

# Browser origins allowed to call the API.
# Example: https://app.example.com,https://admin.example.com
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_ORIGINS=https://app.example.com
KHO_BACKEND_BASE_URL=https://api.example.com

# =============================
# Production PostgreSQL
# =============================
DB_HOST=db
DB_PORT=5432
DB_NAME=vsh_prod
DB_USER=vsh_user
DB_PASS=change-me

# =============================
# Runtime
# =============================
APP_PORT=8000
DOCUMENTS_USE_CELERY=True
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_WORKER_CONCURRENCY=2

# Set these to 0 if migrations/static collection are run as separate deploy steps.
RUN_MIGRATIONS=1
COLLECTSTATIC=1

# =============================
# External integrations
# =============================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VRAIN_API_KEY=
